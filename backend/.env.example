DATABASE_URL=postgresql://postgres:password@localhost:5432/alumnipad
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=5000
FRONTEND_URL=http://localhost:8080

# Optional — if not set, the reset link is returned in the API response (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=AlumniPad <noreply@alumnipad.com>

# Paystack payment gateway (get from dashboard.paystack.com)
# Use sk_test_xxx for development, sk_live_xxx for production
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
